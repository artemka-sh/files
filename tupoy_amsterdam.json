      "dot.pub": ["1.12.12.12", "120.53.53.53"],
      "dns.alidns.com": ["223.5.5.5", "223.6.6.6"],
      "one.one.one.one": ["1.1.1.1", "1.0.0.1"],
      "dns.cloudflare.com": ["104.16.132.229", "104.16.133.229"],
